                                <button class="action-btn btn-view" onclick="viewUserDetail('${user.full_name}')"><i class="fas fa-eye"></i></button>
                                <button class="action-btn btn-delete" onclick="deleteUser('${user.full_name}')"><i class="fas fa-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                `).join('');
            }
        }

