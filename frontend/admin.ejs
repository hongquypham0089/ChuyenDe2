        // Helper to fetch API
        async function fetchAPI(url) {
            try {
                const response = await fetch(url);
                if (!response.ok) throw new Error('Network response was not ok');
                return await response.json();
            } catch (error) {
                console.error('API Fetch Error:', error);
                return null;
            }
        }

        // 1. Dashboard Stats
        async function loadDashboardStats() {
            const stats = await fetchAPI('/api/admin/stats');
            if (stats) {
                document.getElementById('statTotalUsers').textContent = stats.totalUsers || 0;
                document.getElementById('statTotalClubs').textContent = stats.totalClubs || 0;
                document.getElementById('statTotalEvents').textContent = stats.totalEvents || 0;
                
                // Cập nhật thẻ yêu cầu đang chờ nếu có
                const pendingCard = document.querySelector('.card:nth-child(4) .card-value');
                if (pendingCard) pendingCard.textContent = stats.pendingRequests || 0;
            }

            // Load Top Clubs for Dashboard
            const clubs = await fetchAPI('/api/admin/clubs');
            if (clubs) {
                const topTbody = document.getElementById('topClubsTableBody');
                if (topTbody) {
                    topTbody.innerHTML = clubs.slice(0, 5).map(club => `
                        <tr>
                            <td>
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <img src="${club.logo_url || '/placeholder-club.png'}" style="width: 32px; height: 32px; border-radius: 8px; object-fit: cover;">
                                    <span>${club.club_name}</span>
                                </div>
                            </td>
                            <td>${club.member_count}</td>
                            <td>${club.event_count || 0}</td>
                            <td><span class="status-badge status-active">Hoạt động</span></td>
                            <td>
                                <div class="action-buttons">
                                    <button class="action-btn btn-view" onclick="viewClubDetail(${club.id})"><i class="fas fa-eye"></i></button>
                                </div>
                            </td>
                        </tr>
                    `).join('');
                }
            }
        }

