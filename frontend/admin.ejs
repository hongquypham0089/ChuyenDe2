        async function viewClubDetail(clubId) {
            const club = await fetchAPI(`/api/clubs/${clubId}`);
            if (!club) return alert('Không tìm thấy thông tin CLB');

            const members = await fetchAPI(`/api/clubs/${clubId}/members`);
            const stats = await fetchAPI(`/api/clubs/${clubId}/rankings`);

            document.getElementById('detailClubTitle').textContent = club.club_name;
            document.getElementById('detailClubCategory').querySelector('span').textContent = club.category_name || 'Khác';
            document.getElementById('detailClubCreator').querySelector('span').textContent = club.creator_name || 'Hệ thống';
            document.getElementById('detailClubLogo').src = club.logo_url || '/placeholder-club.png';
            
            // Populate Stats
            if (stats && stats.overview) {
                document.getElementById('detailMemberCount').textContent = stats.overview.totalMembers || 0;
                document.getElementById('detailEventCount').textContent = stats.overview.totalEvents || 0;
                document.getElementById('detailPostCount').textContent = stats.overview.totalPosts || 0;
            } else {
                document.getElementById('detailMemberCount').textContent = club.member_count || 0;
                document.getElementById('detailEventCount').textContent = 0;
                document.getElementById('detailPostCount').textContent = 0;
            }

            // Populate Members Table
            const tbody = document.getElementById('clubMembersTable').querySelector('tbody');
            if (members && members.length > 0) {
                tbody.innerHTML = members.map(m => `
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <div style="width: 24px; height: 24px; border-radius: 50%; background: #e2e8f0; display: flex; align-items: center; justify-content: center; overflow: hidden; font-size: 10px;">
                                    ${m.avatar ? `<img src="${m.avatar}" style="width: 100%; height: 100%; object-fit: cover;">` : (m.name ? m.name[0] : 'U')}
                                </div>
                                <span style="font-size: 13px;">${m.name}</span>
                            </div>
                        </td>
                        <td><span class="status-badge ${m.role === 'leader' ? 'status-active' : 'status-pending'}" style="font-size: 10px; padding: 2px 6px;">${m.role}</span></td>
                        <td style="font-size: 12px; color: #64748b;">${m.joined_at ? new Date(m.joined_at).toLocaleDateString('vi-VN') : 'Mới tham gia'}</td>
                    </tr>
                `).join('');
            } else {
                tbody.innerHTML = '<tr><td colspan="3" style="text-align: center; color: #94a3b8;">Chưa có thành viên</td></tr>';
            }

            document.getElementById('clubDetailModal').classList.add('active');
        }

