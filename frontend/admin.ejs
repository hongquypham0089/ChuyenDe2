            .sidebar .logo p,
            .sidebar .admin-details,
            .sidebar .nav-item span {
                display: none;
            }
            
            .main-content {
                margin-left: 80px;
            }
            
            .nav-item {
                justify-content: center;
            }
            
            .nav-item i {
                margin: 0;
            }
        }
