    <script>
        // Chart instances
        let monthlyChart, yearlyChart, monthlyDetailChart, yearlyDetailChart;

        // Initialize charts
        async function initCharts() {
            // Fetch Monthly Data
            const monthlyData = await fetchAPI('/api/admin/reports/monthly');
            const monthlyCtx = document.getElementById('monthlyChart')?.getContext('2d');
            if (monthlyCtx && monthlyData) {
                monthlyChart = new Chart(monthlyCtx, {
                    type: 'line',
                    data: {
                        labels: monthlyData.map(d => d.label),
                        datasets: [
                            {
                                label: 'CLB mới',
                                data: monthlyData.map(d => d.newClubs),
                                borderColor: '#c53030',
                                tension: 0.4
                            },
                            {
                                label: 'Sự kiện',
                                data: monthlyData.map(d => d.newEvents),
                                borderColor: '#2563eb',
                                tension: 0.4
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false
                    }
                });
            }

            // Fetch Yearly Data
            const yearlyData = await fetchAPI('/api/admin/reports/yearly');
            const yearlyCtx = document.getElementById('yearlyChart')?.getContext('2d');
            if (yearlyCtx && yearlyData) {
                yearlyChart = new Chart(yearlyCtx, {
                    type: 'bar',
                    data: {
                        labels: yearlyData.map(d => d.label),
                        datasets: [
                            {
                                label: 'Số CLB',
                                data: yearlyData.map(d => d.totalClubs),
                                backgroundColor: '#c53030'
                            },
                            {
                                label: 'Số sự kiện',
                                data: yearlyData.map(d => d.totalEvents),
                                backgroundColor: '#2563eb'
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false
                    }
                });
            }

            // Monthly Detail Chart
            const monthlyDetailCtx = document.getElementById('monthlyDetailChart')?.getContext('2d');
            if (monthlyDetailCtx) {
                monthlyDetailChart = new Chart(monthlyDetailCtx, {
                    type: 'line',
                    data: {
