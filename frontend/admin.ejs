        // 4. Fetch Events
        async function loadEvents() {
            const events = await fetchAPI('/api/admin/events');
            if (events) {
                const tbody = document.getElementById('eventTableBody');
                if (!tbody) return;
                if (events.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="7" style="text-align: center; padding: 20px; color: #64748b;">Không có sự kiện</td></tr>';
                    return;
                }
                tbody.innerHTML = events.map(event => {
                    const now = new Date();
                    const start = new Date(event.start_time);
                    const end = event.end_time ? new Date(event.end_time) : new Date(start.getTime() + 3600000);
                    
                    let statusClass = 'status-inactive';
                    let statusText = 'Đã kết thúc';
                    
                    if (now < start) {
                        statusClass = 'status-pending';
                        statusText = 'Sắp diễn ra';
                    } else if (now >= start && now <= end) {
                        statusClass = 'status-active';
                        statusText = 'Đang diễn ra';
                    }

                    return `
                        <tr>
                            <td>${event.event_name}</td>
                            <td>${event.club_name}</td>
                            <td>${start.toLocaleDateString('vi-VN')}</td>
                            <td>${event.location || 'Trực tuyến'}</td>
                            <td style="text-align: center; font-weight: 700; color: #c53030;">${event.registration_count || 0}</td>
                            <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                            <td>
                                <div class="action-buttons">
                                    <button class="action-btn btn-view" onclick="viewEventDetail(${event.id})"><i class="fas fa-eye"></i></button>
                                    <button class="action-btn btn-delete" onclick="deleteEvent(${event.id})"><i class="fas fa-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    `;
                }).join('');
            }
        }

