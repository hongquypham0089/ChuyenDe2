            document.getElementById('detailEventCreator').querySelector('span').textContent = event.creator_name || 'Hệ thống';
            document.getElementById('detailEventDesc').textContent = event.description || 'Không có mô tả';
            
            document.getElementById('detailRegCount').textContent = regs ? regs.length : 0;

            // Populate Reg Table
