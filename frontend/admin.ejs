                    <label>Mô tả</label>
                    <textarea placeholder="Mô tả về CLB..."></textarea>
                </div>
                <div class="modal-actions">
                    <button class="btn-save" onclick="saveClub()">Thêm CLB</button>
                    <button class="btn-cancel" onclick="closeModal('addClubModal')">Hủy</button>
                </div>
            </div>
        </div>
    </div>

    <!-- User Detail Modal -->
    <div class="modal" id="userDetailModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Chi tiết người dùng</h2>
                <button class="close-btn" onclick="closeModal('userDetailModal')"><i class="fas fa-times"></i></button>
            </div>
            <div class="user-profile-header">
                <div class="user-avatar-large">NA</div>
                <div>
                    <h3 id="detailUserName">Nguyễn Văn An</h3>
                    <p>MSSV: 20210001</p>
                    <p>Email: an.nguyen@student.edu</p>
                </div>
            </div>
            <div style="margin-top: 20px;">
                <h4>Hoạt động gần đây</h4>
                <table class="table">
                    <tr>
                        <td>Tham gia CLB Tin học</td>
                        <td>01/03/2026</td>
                    </tr>
                    <tr>
                        <td>Đăng ký Workshop React</td>
                        <td>15/03/2026</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Club Detail Modal -->
    <div class="modal" id="clubDetailModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="detailClubName">Chi tiết Câu lạc bộ</h2>
                <button class="close-btn" onclick="closeModal('clubDetailModal')"><i class="fas fa-times"></i></button>
            </div>
            <div class="club-profile-header" style="display: flex; gap: 20px; align-items: center; padding: 20px; background: #f8fafc; border-radius: 12px; margin-bottom: 20px;">
                <img id="detailClubLogo" src="/placeholder-club.png" style="width: 100px; height: 100px; border-radius: 12px; object-fit: cover; border: 3px solid white; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);">
                <div>
                    <h3 id="detailClubTitle" style="font-size: 24px; color: #1e293b; margin-bottom: 5px;">CLB Tên</h3>
                    <p id="detailClubCategory" style="color: #64748b; font-weight: 500;"><i class="fas fa-tag"></i> <span>Chuyên mục</span></p>
                    <p id="detailClubCreator" style="color: #64748b; font-size: 14px;"><i class="fas fa-user-edit"></i> Người tạo: <span>Tên người tạo</span></p>
                </div>
            </div>
            <div class="grid" style="grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 25px;">
                <div class="card" style="padding: 15px; text-align: center; background: #fff1f2; border: 1px solid #fecdd3;">
                    <div style="font-size: 20px; font-weight: 700; color: #e11d48;" id="detailMemberCount">0</div>
                    <div style="font-size: 12px; color: #9f1239;">Thành viên</div>
                </div>
                <div class="card" style="padding: 15px; text-align: center; background: #eff6ff; border: 1px solid #bfdbfe;">
                    <div style="font-size: 20px; font-weight: 700; color: #2563eb;" id="detailEventCount">0</div>
                    <div style="font-size: 12px; color: #1e40af;">Sự kiện</div>
                </div>
                <div class="card" style="padding: 15px; text-align: center; background: #f0fdf4; border: 1px solid #bbf7d0;">
                    <div style="font-size: 20px; font-weight: 700; color: #16a34a;" id="detailPostCount">0</div>
                    <div style="font-size: 12px; color: #166534;">Bài viết</div>
                </div>
            </div>
            
            <div style="margin-top: 20px;">
                <h4 style="margin-bottom: 10px; border-bottom: 2px solid #ef4444; display: inline-block;">Danh sách thành viên</h4>
                <div style="max-height: 250px; overflow-y: auto;">
                    <table class="table" id="clubMembersTable">
                        <thead>
                            <tr>
                                <th>Thành viên</th>
                                <th>Vai trò</th>
                                <th>Ngày tham gia</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Data populated by JS -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Event Detail Modal -->
    <div class="modal" id="eventDetailModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="detailEventTitleHead">Chi tiết Sự kiện</h2>
                <button class="close-btn" onclick="closeModal('eventDetailModal')"><i class="fas fa-times"></i></button>
            </div>
            <div class="event-profile-header" style="padding: 20px; background: #f8fafc; border-radius: 12px; margin-bottom: 20px;">
                <h3 id="detailEventName" style="font-size: 24px; color: #1e293b; margin-bottom: 10px;">Tên Sự kiện</h3>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; font-size: 14px; color: #64748b;">
                    <p id="detailEventClub"><i class="fas fa-university"></i> Tổ chức: <span>Tên CLB</span></p>
                    <p id="detailEventLocation"><i class="fas fa-map-marker-alt"></i> Địa điểm: <span>Địa điểm</span></p>
                    <p id="detailEventTime"><i class="fas fa-clock"></i> Thời gian: <span>Thời gian</span></p>
                    <p id="detailEventCreator"><i class="fas fa-user"></i> Người tạo: <span>Tên người tạo</span></p>
                </div>
                <div id="detailEventDesc" style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #e2e8f0; font-size: 14px; color: #475569; line-height: 1.6;">
                    Mô tả sự kiện...
                </div>
            </div>
            
            <div style="margin-top: 20px;">
                <h4 style="margin-bottom: 10px; border-bottom: 2px solid #2563eb; display: inline-block;">Danh sách đăng ký (<span id="detailRegCount">0</span>)</h4>
                <div style="max-height: 300px; overflow-y: auto;">
                    <table class="table" id="eventRegTable">
                        <thead>
                            <tr>
                                <th>Người dùng</th>
                                <th>Email</th>
                                <th>Ngày đăng ký</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Data populated by JS -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    
    <div style="margin-left: var(--sidebar-width);">
        <%- include('partials/Footer') %>
    </div>
    <!-- Core Admin Logic -->
    <!-- Award Points Modal -->
    <div class="modal" id="awardPointsModal">
        <div class="modal-content" style="max-width: 500px;">
            <div class="modal-header">
                <h2>Cộng điểm rèn luyện</h2>
                <button class="close-btn" onclick="closeModal('awardPointsModal')"><i class="fas fa-times"></i></button>
            </div>
            <form id="awardPointsForm">
                <div class="form-group">
                    <label>MSSV hoặc Email sinh viên</label>
                    <input type="text" id="awardPointsUser" placeholder="Gõ để tìm sinh viên..." required list="studentList">
                    <datalist id="studentList"></datalist>
                </div>
                <div class="form-group">
                    <label>Số điểm cộng</label>
                    <input type="number" id="awardPointsValue" value="5" min="1" max="100" required>
                </div>
                <div class="form-group">
                    <label>Lý do cộng điểm</label>
                    <textarea id="awardPointsReason" placeholder="Ví dụ: Tham gia tích cực hoạt động tình nguyện..." required></textarea>
                </div>
                <button type="submit" class="btn-submit-mod">
                    <i class="fas fa-star"></i> Xác nhận cộng điểm
                </button>
            </form>
        </div>
    </div>

    <script src="/JS/admin.js?v=3"></script>
</body>
</html>