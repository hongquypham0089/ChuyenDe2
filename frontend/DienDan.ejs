    <!-- Create Post Modal -->
    <div class="modal" id="createPostModal">
        <div class="modal-content create-post-modal">
            <div class="modal-header">
                <h2>Tạo bài viết mới</h2>
                <button class="close-btn" onclick="closeModal('createPostModal')"><i class="fas fa-times"></i></button>
            </div>

            <form id="createPostForm" onsubmit="event.preventDefault(); createPost();">
                <div class="form-group">
                    <label>Tiêu đề</label>
                    <input type="text" id="postTitle" placeholder="Nhập tiêu đề bài viết..." required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Danh mục</label>
                        <select id="postCategory" required>
                            <option value="">Chọn danh mục</option>
                            <option value="announcement">Thông báo</option>
                            <option value="study">Học tập</option>
                            <option value="career">Việc làm</option>
                            <option value="material">Tài liệu</option>
                            <option value="social">Giao lưu</option>
                            <option value="qa">Hỏi đáp</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Tags (phân cách bằng dấu phẩy)</label>
                        <input type="text" id="postTags" placeholder="VD: học tập, kinh nghiệm, lập trình">
                    </div>
                </div>

                <div class="form-group">
                    <label>Nội dung</label>
                    <textarea id="postContent" placeholder="Viết nội dung bài viết..." required></textarea>
                </div>

                <div class="form-group">
                    <label>Đính kèm hình ảnh/tài liệu</label>
                    <input type="file" id="postAttachment" multiple accept="image/*,.pdf,.doc,.docx">
                </div>

                <div class="form-group">
                    <label style="display: flex; align-items: center; gap: 8px;">
                        <input type="checkbox" id="pinPost"> Ghim bài viết (chỉ dành cho Admin)
                    </label>
                </div>

                <div style="display: flex; gap: 16px; margin-top: 24px;">
                    <button type="submit" class="btn-create" style="flex: 2;">Đăng bài</button>
                    <button type="button" class="btn-create" style="flex: 1; background: #f1f5f9; color: #1a2639;" onclick="closeModal('createPostModal')">Hủy</button>
                </div>
            </form>
        </div>
    </div>
