<!-- Create Post Modal -->
<div class="modal" id="createPostModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Tạo bài viết mới</h3>
            <button class="close-btn" onclick="closeModal('createPostModal')"><i class="fas fa-times"></i></button>
        </div>

        <div class="modal-user-info">
            <div class="modal-user-avatar">NA</div>
            <div class="modal-user-details">
                <div class="modal-user-name">Nguyễn Văn A</div>
                <div class="post-privacy-select">
                    <i class="fas fa-globe"></i> Công khai
                    <i class="fas fa-chevron-down"></i>
                </div>
            </div>
        </div>

        <textarea class="modal-post-input" id="postContent" placeholder="Bạn đang nghĩ gì?"></textarea>

        <div class="media-upload-area" onclick="document.getElementById('postMedia').click()" id="uploadArea">
            <i class="fas fa-cloud-upload-alt"></i>
            <p>Thêm ảnh hoặc video</p>
            <p style="font-size: 12px; color: #94a3b8;">Hỗ trợ JPG, PNG, MP4 (tối đa 20MB)</p>
        </div>
        <input type="file" id="postMedia" accept="image/*,video/*" style="display: none;" onchange="previewMedia(this)">

        <div class="media-preview" id="mediaPreview">
            <img src="" alt="Preview" id="previewImage">
            <video controls id="previewVideo" style="display: none;">
                <source src="" type="video/mp4">
            </video>
            <button class="remove-media" onclick="removeMedia()"><i class="fas fa-times"></i></button>
        </div>

        <div class="modal-actions">
            <button class="btn-primary" onclick="createPost()">
                <i class="fas fa-paper-plane"></i> Đăng bài
            </button>
            <button class="btn-secondary" onclick="closeModal('createPostModal')">
                Hủy
            </button>
        </div>
    </div>
</div>

