<%- include('partials/Header') %>
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <i class="fas fa-user-circle"></i>
            <h2>Chào bạn!</h2>
            <p>Tham gia cộng đồng CLB Connect ngay</p>
        </div>

        <!-- Tabs chuyển đổi Đăng nhập / Đăng ký -->
        <div class="auth-tabs">
            <div class="auth-tab active" id="loginTab" onclick="switchTab('login')">Đăng nhập</div>
            <div class="auth-tab" id="registerTab" onclick="switchTab('register')">Đăng ký</div>
        </div>

        <!-- FORM ĐĂNG NHẬP -->
        <div class="auth-form" id="loginForm">
            <div class="form-group">
                <label>Email hoặc tên đăng nhập</label>
                <div class="input-with-icon">
                    <i class="fas fa-envelope"></i>
                    <input type="text" placeholder="Nhập email hoặc username" id="loginEmail">
                </div>
            </div>
            <div class="form-group">
                <label>Mật khẩu</label>
                <div class="input-with-icon">
                    <i class="fas fa-lock"></i>
                    <input type="password" placeholder="••••••••" id="loginPassword">
                </div>
            </div>
            <div class="forgot-password">
                <a href="#">Quên mật khẩu?</a>
            </div>
            <button class="btn-auth" onclick="handleLogin()">
                <i class="fas fa-sign-in-alt"></i> Đăng nhập
            </button>

            <div class="divider">
                <span>hoặc đăng nhập với</span>
            </div>
            <div class="social-login">
                <div class="social-btn" onclick="alert('Đăng nhập với Google')"><i class="fab fa-google"></i></div>
                <div class="social-btn" onclick="alert('Đăng nhập với Facebook')"><i class="fab fa-facebook-f"></i></div>
                <div class="social-btn" onclick="alert('Đăng nhập với GitHub')"><i class="fab fa-github"></i></div>
            </div>
        </div>

        <!-- FORM ĐĂNG KÝ (ẩn ban đầu) -->
        <div class="auth-form form-hidden" id="registerForm">
            <div class="form-group">
                <label>Họ và tên</label>
                <div class="input-with-icon">
                    <i class="fas fa-user"></i>
                    <input type="text" placeholder="Nguyễn Văn A" id="regName">
                </div>
            </div>
            <div class="form-group">
                <label>Email</label>
                <div class="input-with-icon">
                    <i class="fas fa-envelope"></i>
                    <input type="email" placeholder="your.email@example.com" id="regEmail">
                </div>
            </div>
            <div class="form-group">
                <label>Tên đăng nhập</label>
                <div class="input-with-icon">
                    <i class="fas fa-at"></i>
                    <input type="text" placeholder="username" id="regUsername">
                </div>
            </div>
            <div class="form-group">
                <label>Mật khẩu</label>
                <div class="input-with-icon">
                    <i class="fas fa-lock"></i>
                    <input type="password" placeholder="Tối thiểu 6 ký tự" id="regPassword">
                </div>
            </div>
            <div class="form-group">
                <label>Xác nhận mật khẩu</label>
                <div class="input-with-icon">
                    <i class="fas fa-lock"></i>
                    <input type="password" placeholder="Nhập lại mật khẩu" id="regConfirm">
                </div>
            </div>

            <div class="terms">
                <input type="checkbox" id="agreeTerms">
                <label for="agreeTerms">Tôi đồng ý với <a href="#">Điều khoản dịch vụ</a> và <a href="#">Chính sách bảo mật</a>.</label>
            </div>

            <button class="btn-auth" onclick="handleRegister()">
                <i class="fas fa-user-plus"></i> Đăng ký
            </button>

            <div class="divider">
                <span>hoặc đăng ký với</span>
            </div>
            <div class="social-login">
                <div class="social-btn" onclick="alert('Đăng ký với Google')"><i class="fab fa-google"></i></div>
                <div class="social-btn" onclick="alert('Đăng ký với Facebook')"><i class="fab fa-facebook-f"></i></div>
                <div class="social-btn" onclick="alert('Đăng ký với GitHub')"><i class="fab fa-github"></i></div>
            </div>
        </div>
    </div>

    <!-- Thông điệp bảo mật -->
    <div class="security-note">
        <i class="fas fa-shield-alt"></i> Thông tin của bạn được bảo mật tuyệt đối
    </div>
</div>

<%- include('partials/Footer') %>
<script src="JS/dangnhap.js"></script>
<link rel="stylesheet" href="CSS/dangnhap.css">