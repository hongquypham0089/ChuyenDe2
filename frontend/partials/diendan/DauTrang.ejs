<!-- Club Hero / Header Section -->
<div class="club-hero" id="clubHero" style="display: none;">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <div class="club-logo-large" id="clubLogoLarge">
            <i class="fas fa-users"></i>
        </div>
        <div class="club-info-main">
            <h1 id="clubNameDisplay">Tên Câu lạc bộ</h1>
            <p id="clubDescDisplay">Mô tả ngắn về câu lạc bộ và các hoạt động chính.</p>
            <div class="club-meta-tags">
                <span id="clubCategory"><i class="fas fa-tag"></i> Học thuật</span>
                <span id="clubMemberCount"><i class="fas fa-user-friends"></i> 0 thành viên</span>
                <span id="clubLeaderName"><i class="fas fa-crown"></i> Trưởng CLB: ...</span>
            </div>
        </div>
        <div class="hero-actions" id="heroActions">
            <!-- Nút sẽ được thêm động bằng JS -->
        </div>
    </div>
</div>
