<!-- Modal: Tao bai viet moi -->
<div class="modal" id="createPostModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Tạo bài viết mới</h2>
            <button class="close-btn" onclick="closeModal('createPostModal')">&times;</button>
        </div>
        <form id="postForm" class="no-scrollbar" onsubmit="submitCreatePost(event)">
            <div class="form-group">
                <label>Tiêu đề bài viết</label>
                <input type="text" id="postTitle" placeholder="Nhập tiêu đề..." required>
            </div>
            <div class="form-group">
                <label>Loại bài viết</label>
                <select id="postType">
                    <option value="thảo luận">Thảo luận</option>
                    <option value="thông báo">Thông báo</option>
                    <option value="chia sẻ">Chia sẻ tài liệu</option>
                </select>
            </div>
            <div class="form-group">
                <label>Nội dung</label>
                <textarea id="postContent" rows="5" placeholder="Bạn đang nghĩ gì?..." required></textarea>
            </div>
            <div class="form-group">
                <label>Ảnh đính kèm</label>
                <input type="file" id="postImage" accept="image/*">
            </div>
            <button type="submit" class="btn-submit">Đăng bài ngay</button>
        </form>
    </div>
</div>

<!-- Modal: Tao su kien -->
<div class="modal" id="createEventModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Hành động Trưởng CLB: Tạo sự kiện mới</h2>
            <button class="close-btn" onclick="closeModal('createEventModal')">&times;</button>
        </div>
        <form id="eventForm" class="no-scrollbar" onsubmit="submitCreateEvent(event)">
            <div class="form-group">
                <label>Tên sự kiện</label>
                <input type="text" id="eventName" placeholder="VD: Workshop Lập trình Web" required>
            </div>
            <div class="form-group">
                <label>Mô tả sự kiện</label>
                <textarea id="eventDesc" rows="3" placeholder="Chi tiết hoạt động..." required></textarea>
            </div>
            <div class="form-group">
                <label>Địa điểm</label>
                <input type="text" id="eventLoc" placeholder="Phòng học, Sân trường, Online..." required>
            </div>
            <div class="form-row" style="display: flex; gap: 15px;">
                <div class="form-group" style="flex: 1;">
                    <label>Bắt đầu</label>
                    <input type="datetime-local" id="eventStart" required>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label>Kết thúc</label>
                    <input type="datetime-local" id="eventEnd" required>
                </div>
            </div>
            <div class="form-group">
                <label>Ảnh đại diện Sự kiện (tùy chọn)</label>
                <input type="file" id="eventImage" accept="image/*">
            </div>
            <button type="submit" class="btn-submit">Công bố sự kiện</button>
        </form>
    </div>
</div>

<!-- Modal: Sua bai viet -->
<div class="modal" id="editPostModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Chỉnh sửa bài viết</h2>
            <button class="close-btn" onclick="closeModal('editPostModal')">&times;</button>
        </div>
        <form id="editPostForm" class="no-scrollbar" onsubmit="submitEditPost(event)">
            <input type="hidden" id="editPostId">
            <div class="form-group">
                <label>Tiêu đề bài viết</label>
                <input type="text" id="editPostTitle" required>
            </div>
            <div class="form-group">
                <label>Loại bài viết</label>
                <select id="editPostType">
                    <option value="thảo luận">Thảo luận</option>
                    <option value="thông báo">Thông báo</option>
                    <option value="chia sẻ">Chia sẻ tài liệu</option>
                </select>
            </div>
            <div class="form-group">
                <label>Nội dung</label>
                <textarea id="editPostContent" rows="5" required></textarea>
            </div>
            <div class="form-group">
                <label>Ảnh đính kèm mới (tùy chọn)</label>
                <input type="file" id="editPostImage" accept="image/*">
            </div>
            <button type="submit" class="btn-submit">Cập nhật bài viết</button>
        </form>
    </div>
</div>

