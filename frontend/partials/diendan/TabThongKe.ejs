<!-- Stats Tab -->
<section id="tab-stats" class="tab-pane">
    <div class="content-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h2>Bảng vàng & Thống kê</h2>
        <div class="period-toggle" style="background: #f1f5f9; padding: 4px; border-radius: 10px; display: flex; gap: 4px;">
            <button id="btnMonth" onclick="changeStatsPeriod('month')" class="active"
                style="padding: 6px 14px; border: none; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; transition: 0.2s;">Tháng này</button>
            <button id="btnYear" onclick="changeStatsPeriod('year')"
                style="padding: 6px 14px; border: none; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; transition: 0.2s; background: none; color: #64748b;">Năm nay</button>
            <button id="btnAll" onclick="changeStatsPeriod('all')"
                style="padding: 6px 14px; border: none; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; transition: 0.2s; background: none; color: #64748b;">Tất cả</button>
        </div>
    </div>

    <!-- Tổng quan CLB -->
    <div class="stats-overview" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 30px;">
        <div class="stat-card" style="background: white; padding: 20px; border-radius: 16px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 15px;">
            <div style="width: 48px; height: 48px; background: #eff6ff; color: #2563eb; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">
                <i class="fas fa-calendar-check"></i>
            </div>
            <div>
                <div id="statTotalEvents" style="font-size: 22px; font-weight: 800; color: #0f172a;">0</div>
                <div style="font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">Sự kiện tổ chức</div>
            </div>
        </div>
        <div class="stat-card" style="background: white; padding: 20px; border-radius: 16px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 15px;">
            <div style="width: 48px; height: 48px; background: #fef2f2; color: #ef4444; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">
                <i class="fas fa-file-alt"></i>
            </div>
            <div>
                <div id="statTotalPosts" style="font-size: 22px; font-weight: 800; color: #0f172a;">0</div>
                <div style="font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">Bài viết thảo luận</div>
            </div>
        </div>
        <div class="stat-card" style="background: white; padding: 20px; border-radius: 16px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 15px;">
            <div style="width: 48px; height: 48px; background: #f0fdf4; color: #16a34a; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">
                <i class="fas fa-users"></i>
            </div>
            <div>
                <div style="display: flex; align-items: baseline; gap: 8px;">
                    <div id="statTotalMembers" style="font-size: 22px; font-weight: 800; color: #0f172a;">0</div>
                    <div id="newMembersBadge" style="font-size: 11px; background: #dcfce7; color: #16a34a; padding: 2px 8px; border-radius: 50px; font-weight: 700; display: none;">+0 mới</div>
                </div>
                <div style="font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">Thành viên tích cực</div>
            </div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
        <!-- Xếp hạng Sự kiện -->
        <div class="ranking-panel">
            <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 20px; color: #334155;"><i class="fas fa-medal" style="color: #fbbf24;"></i> Siêu sao sự kiện</h3>
            <div id="eventRankingsList" style="display: flex; flex-direction: column; gap: 12px;">
                <!-- Top members for events -->
            </div>
        </div>

        <!-- Xếp hạng Bài viết -->
        <div class="ranking-panel">
            <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 20px; color: #334155;"><i class="fas fa-fire" style="color: #f97316;"></i> Thành viên sôi nổi</h3>
            <div id="postRankingsList" style="display: flex; flex-direction: column; gap: 12px;">
                <!-- Top members for posts -->
            </div>
        </div>
    </div>
</section>
