<!-- Feed Tab -->
<section id="tab-feed" class="tab-pane active">
    <!-- Chỗ này sẽ hiện nếu đã chọn CLB -->
    <div id="clubDashboardContent">
        <div class="content-header">
            <h2>Bản tin thảo luận</h2>
            <div style="display: flex; gap: 10px;">
                <div class="search-box" style="position: relative;">
                    <i class="fas fa-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #94a3b8;"></i>
                    <input type="text" id="searchInput" placeholder="Tìm kiếm bài viết..."
                        style="padding: 10px 15px 10px 35px; border: 1px solid #e2e8f0; border-radius: 8px; width: 250px; font-family: inherit; font-size: 14px;"
                        onkeyup="handleSearch(event)">
                </div>
                <button class="btn-primary" id="btnCreatePost" style="display: none;" onclick="openModal('createPostModal')">
                    <i class="fas fa-edit"></i> Đăng bài mới
                </button>
            </div>
        </div>
        <div id="postsList" class="posts-grid">
            <div class="loading-placeholder">Đang tải bài viết...</div>
        </div>
    </div>

    <!-- Chỗ này sẽ hiện nếu CHƯA chọn CLB (Truy cập từ Header) -->
    <div id="noClubSelectedView" style="display: none; text-align: center; padding: 60px 20px;">
        <div style="font-size: 60px; color: #cbd5e1; margin-bottom: 20px;">
            <i class="fas fa-layer-group"></i>
        </div>
        <h2 style="font-size: 28px; margin-bottom: 10px;">Chào mừng bạn đến với Diễn đàn CLB</h2>
        <p style="color: #64748b; margin-bottom: 30px;">Vui lòng chọn một câu lạc bộ bạn đã tham gia để bắt đầu quản lý và thảo luận.</p>

        <div id="myClubsList" class="events-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 10px;">
            <!-- Danh sách CLB của tôi sẽ load ở đây -->
        </div>

        <div style="margin-top: 40px; border-top: 1px solid #e2e8f0; padding-top: 30px;">
            <p>Bạn chưa tham gia CLB nào?</p>
            <a href="/clb" class="btn-primary" style="display: inline-flex; margin-top: 15px; text-decoration: none;">
                <i class="fas fa-search"></i> Khám phá các câu lạc bộ
            </a>
        </div>
    </div>
</section>
