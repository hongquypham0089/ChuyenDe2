<style>
    /* =========================
       HEADER STYLES ONLY
    ========================= */
    .newspaper-header {
        font-family: 'Inter', sans-serif;
        background: white;
        border-bottom: 3px solid #c53030;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .header-top {
        background: linear-gradient(135deg, #1a2639 0%, #2d3748 100%);
        color: white;
        padding: 8px 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
    }

    .header-top-left span {
        margin-right: 24px;
    }

    .header-top-right i {
        margin-left: 16px;
        cursor: pointer;
        transition: color 0.2s;
    }

    .header-top-right i:hover {
        color: #c53030;
    }

    .header-main {
        padding: 0 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: white;
    }

    .logo-section {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .logo {
        font-family: 'Playfair Display', serif;
        font-size: 36px;
        font-weight: 800;
        color: #c53030;
        letter-spacing: -1px;
        text-decoration: none;
    }

    .logo span {
        color: #1a2639;
        font-size: 14px;
        font-weight: 400;
        margin-left: 8px;
        font-family: 'Inter', sans-serif;
    }

    .edition {
        border-left: 2px solid #e2e8f0;
        padding-left: 20px;
        font-size: 14px;
        color: #4a5568;
    }

    .edition .date {
        font-weight: 700;
        color: #c53030;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 20px;
        background: #f1f5f9;
        padding: 8px 16px 8px 20px;
        border-radius: 40px;
        transition: all 0.2s;
        cursor: pointer;
    }

    .user-info:hover {
        background: #e2e8f0;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        background: #c53030;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        text-transform: uppercase;
        overflow: hidden;
        /* Đảm bảo ảnh không tràn ra ngoài vòng tròn */
    }

    .nav-bar {
        background: white;
        padding: 0 40px;
        border-top: 1px solid #e2e8f0;
    }

    .nav-links {
        display: flex;
        list-style: none;
        gap: 32px;
        margin: 0;
        padding: 0;
    }

    .nav-links li {
        padding: 16px 0;
        font-weight: 500;
        cursor: pointer;
        border-bottom: 3px solid transparent;
        transition: all 0.2s;
        position: relative;
    }

    .nav-links li:hover,
    .nav-links li.active {
        color: #c53030;
        border-bottom-color: #c53030;
    }

    .nav-links li.active::after {
        content: '';
        position: absolute;
        bottom: -3px;
        left: 0;
        right: 0;
        height: 3px;
        background: #c53030;
        border-radius: 3px 3px 0 0;
    }





    /* Style cho Dropdown Menu */
    .user-dropdown-content {
        display: none;
        /* Mặc định ẩn */
        position: absolute;
        top: 110%;
        right: 0;
        background-color: white;
        min-width: 160px;
        box-shadow: 0px 8px 16px 0px rgba(0, 0, 0, 0.1);
        border-radius: 8px;
        z-index: 1000;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }

    /* Notification specific styles - Premium Redesign */
    #noti-btn {
        transition: transform 0.2s ease;
    }

    #noti-btn:hover {
        transform: scale(1.05);
    }

    .noti-badge {
        position: absolute;
        top: 2px;
        right: 2px;
        background: #e53e3e;
        color: white;
        font-size: 10px;
        font-weight: 800;
        min-width: 18px;
        height: 18px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid white;
        box-shadow: 0 0 0 2px rgba(229, 62, 62, 0.2);
        animation: pulse-red 2s infinite;
    }

    @keyframes pulse-red {
        0% {
            box-shadow: 0 0 0 0 rgba(229, 62, 62, 0.7);
        }

        70% {
            box-shadow: 0 0 0 6px rgba(229, 62, 62, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(229, 62, 62, 0);
        }
    }

    #noti-dropdown {
        padding: 0;
        margin-top: 15px;
        width: 360px !important;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        transform-origin: top right;
        transition: opacity 0.2s ease, transform 0.2s ease;
        opacity: 0;
        transform: translateY(-10px) scale(0.95);
        pointer-events: none;
        display: block !important;
        visibility: hidden;
    }

    #noti-dropdown.show {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
        visibility: visible;
    }

    .noti-header {
        padding: 16px 20px;
        border-bottom: 1px solid #edf2f7;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(8px);
        position: sticky;
        top: 0;
        z-index: 10;
        border-top-left-radius: 16px;
        border-top-right-radius: 16px;
    }

    .noti-header span {
        font-weight: 800;
        font-size: 16px;
        color: #2d3748;
    }

    .noti-header button {
        background: none;
        border: none;
        color: #3182ce;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: color 0.2s;
    }

    .noti-header button:hover {
        color: #2b6cb0;
        text-decoration: underline;
    }

    .noti-item {
        padding: 16px 20px;
        border-bottom: 1px solid #f7fafc;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        gap: 12px;
        text-decoration: none !important;
        background: #ffffff;
    }

    .noti-item:last-child {
        border-bottom: none;
    }

    .noti-item:hover {
        background: #f8fafc;
    }

    .noti-item.unread {
        background: #ebf8ff;
    }

    .noti-item.unread .noti-title {
        color: #2b6cb0;
    }

    .noti-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 16px;
    }

    .noti-icon.membership {
        background: #ebf4ff;
        color: #3182ce;
    }

    .noti-icon.post {
        background: #f0fff4;
        color: #38a169;
    }

    .noti-icon.event {
        background: #fffaf0;
        color: #dd6b20;
    }

    .noti-icon.default {
        background: #edf2f7;
        color: #718096;
    }

    .noti-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
    }

    .noti-item .noti-title {
        font-weight: 700;
        font-size: 14px;
        color: #2d3748;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .noti-indicator {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #3182ce;
        display: none;
    }

    .noti-item.unread .noti-indicator {
        display: block;
    }

    .noti-item .noti-msg {
        font-size: 13px;
        color: #4a5568;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .noti-item .noti-time {
        font-size: 11px;
        color: #a0aec0;
        font-weight: 500;
        margin-top: 2px;
    }



    .user-dropdown-content a {
        color: #2d3748;
        padding: 12px 16px;
        text-decoration: none;
        display: block;
        font-size: 14px;
        transition: background 0.2s;
    }

    .user-dropdown-content a:hover {
        background-color: #f7fafc;
        color: #c53030;
    }

    /* .user-dropdown-content.show was used for displaying it */
    .user-dropdown-content.show {
        display: block !important;
    }


    /* =========================
       TỐI ƯU RESPONSIVE
    ========================= */

    /* Cho Tablet (Màn hình vừa) */
    @media (max-width: 1024px) {
        .header-top {
            padding: 8px 20px;
        }

        .header-main {
            padding: 15px;
        }

        .nav-bar {
            padding: 0 20px;
        }

        .nav-links {
            gap: 24px;
        }
    }

    /* Cho Điện thoại (Màn hình nhỏ) */
    @media (max-width: 768px) {
        .header-top {
            display: none;
            /* Ẩn dải màu đen trên cùng cho đỡ tốn diện tích màn hình đt */
        }

        .header-main {
            flex-direction: column;
            gap: 15px;
            padding: 15px;
        }

        .logo-section {
            flex-direction: column;
            text-align: center;
            gap: 10px;
        }

        .logo {
            font-size: 28px;
            /* Thu nhỏ logo */
        }

        .edition {
            border-left: none;
            padding-left: 0;
            border-top: 1px solid #e2e8f0;
            /* Chuyển vạch dọc thành vạch ngang */
            padding-top: 10px;
        }

        .nav-bar {
            padding: 0;
            /* Bỏ padding để thanh menu tràn viền màn hình */
        }

        /* Chuyển menu thành dạng vuốt ngang trên mobile */
        .nav-links {
            flex-wrap: nowrap;
            overflow-x: auto;
            justify-content: flex-start;
            padding: 0 15px;
            gap: 20px;
            -webkit-overflow-scrolling: touch;
            /* Giúp vuốt mượt trên iOS */
        }

        /* Ẩn thanh cuộn ngang để giao diện sạch hơn */
        .nav-links::-webkit-scrollbar {
            display: none;
        }

        .nav-links {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .nav-links li {
            white-space: nowrap;
            /* Không cho rớt dòng text */
            padding: 12px 0;
            font-size: 14px;
        }

    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="/CSS/bien.css">
<script src="/socket.io/socket.io.js"></script>

<header class="newspaper-header">
    <div class="header-top">
        <div class="header-top-left"></div>
        <div class="header-top-right"></div>
    </div>

    <div class="header-main">
        <div class="logo-section">
            <a href="/" class="logo">
                CLB Connect<span>.vn</span>
            </a>
            <div class="edition">
                <span class="date">Kết nối đam mê</span><br>
                Nơi hội tụ tinh hoa sinh viên
            </div>
        </div>
        <div style="display: flex; align-items: center; gap: 20px; margin-left: auto;">
            <!-- Notification Bell -->
            <div id="noti-btn" style="position: relative; cursor: pointer; padding: 10px;">
                <i class="fas fa-bell" style="font-size: 20px; color: #4a5568;"></i>
                <div id="noti-count" class="noti-badge" style="display: none;">0</div>

                <div id="noti-dropdown" class="user-dropdown-content">
                    <div class="noti-header">
                        <span>Thông báo</span>
                        <button onclick="markAllAsRead()">Đọc tất cả</button>
                    </div>
                    <div id="noti-list-container" style="max-height: 400px; overflow-y: auto;">
                        <div style="padding: 30px; text-align: center; color: #a0aec0; font-style: italic;">
                            Đang tải thông báo...
                        </div>
                    </div>
                </div>
            </div>

            <div class="user-info" id="user-profile-btn" style="position: relative;">
                <span>Xin chào, <strong id="username">Khách</strong></span>
                <div class="user-avatar" id="userAvatar">?</div>

                <div id="user-dropdown" class="user-dropdown-content">
                    <a href="/Profile" onclick="window.location.href='/profile';">
                        <i class="fas fa-user-circle"></i> Trang cá nhân
                    </a>
                    <hr>
                    <a href="#" id="logout-btn"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
                </div>
            </div>
        </div>
    </div>

    <div class="nav-bar">
        <ul class="nav-links">
            <li class="<%= title === 'Trang chủ - CLB' ? 'active' : '' %>">
                <a href="/" style="text-decoration: none; color: inherit;">Trang chủ</a>
            </li>
            <li class="<%= title === 'Danh sách Câu lạc bộ' ? 'active' : '' %>">
                <a href="/clb" style="text-decoration: none; color: inherit;">Câu lạc bộ</a>
            </li>

            <li class="<%= title === 'TinTuc' ? 'active' : '' %>">
                <a href="/TinTuc" style="text-decoration: none; color: inherit;">Tin tức</a>
            </li>
            <li class="<%= title === 'Diễn đàn' ? 'active' : '' %>">
                <a href="/DienDan" style="text-decoration: none; color: inherit;">Diễn đàn</a>
            </li>
            <li id="nav-ketnoi" class="<%= title === 'Kết nối Nhà trường' ? 'active' : '' %>">
                <a href="/KetNoi" id="nav-ketnoi-text" style="text-decoration: none; color: inherit;">Kết nối</a>
            </li>
            <li class="<%= title === 'Xếp hạng' ? 'active' : '' %>">
                <a href="/XepHang" style="text-decoration: none; color: inherit;">Xếp hạng</a>
            </li>
        </ul>
    </div>
</header>

<!-- Toast Container -->
<div id="thong-bao-toast"></div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const storedUser = localStorage.getItem('currentUser');
        const usernameEl = document.getElementById("username");
        const avatarEl = document.getElementById("userAvatar");
        const profileBtn = document.getElementById("user-profile-btn");
        const dropdown = document.getElementById("user-dropdown");
        const logoutBtn = document.getElementById("logout-btn");

        if (storedUser) {
            const user = JSON.parse(storedUser);

            if (user.isLoggedIn && user.name) {
                usernameEl.textContent = user.name;

                // KIỂM TRA ROLE ADMIN ĐỂ HIỂN THỊ LINK QUẢN TRỊ
                if (user.role === 'admin') {
                    const adminLink = document.createElement('a');
                    adminLink.href = '/admin';
                    adminLink.innerHTML = `<i class="fas fa-user-shield" style="color: #c53030;"></i> Quản trị hệ thống`;
                    dropdown.prepend(adminLink);
                }

                // KIỂM TRA ROLE VÀ CẬP NHẬT MENU HỖ TRỢ/KẾT NỐI
                const ketnoiLink = document.getElementById('nav-ketnoi-text');
                if (ketnoiLink) {
                    if (user.role === 'leader') {
                        ketnoiLink.innerText = 'Kết nối';
                    } else {
                        ketnoiLink.innerText = 'Hỗ trợ';
                    }
                }

                // KIỂM TRA AVATAR: Nếu có ảnh thì hiển thị ảnh, ngược lại hiển thị chữ cái đầu
                if (user.avatar) {
                    avatarEl.innerHTML = `<img src="${user.avatar}" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover;">`;
                } else {
                    avatarEl.textContent = user.name.charAt(0).toUpperCase();
                    avatarEl.style.background = "#c53030";
                }

                // Click vào profile để bật/tắt menu sổ xuống
                profileBtn.onclick = function (e) {
                    if (e.target.closest('a')) {
                        return;
                    }

                    e.stopPropagation(); // Ngăn sự kiện click lan ra ngoài window
                    dropdown.classList.toggle("show");
                };

                // Xử lý nút Đăng xuất trong menu
                logoutBtn.onclick = function (e) {
                    e.preventDefault();
                    if (confirm("Bạn có muốn đăng xuất không?")) {
                        localStorage.removeItem('currentUser');
                        window.location.reload();
                    }
                };

                // --- Notification Handling ---
                const notiBtn = document.getElementById('noti-btn');
                const notiDropdown = document.getElementById('noti-dropdown');

                if (notiBtn) {
                    notiBtn.onclick = function (e) {
                        e.stopPropagation();
                        notiDropdown.classList.toggle("show");
                        // Close user dropdown if open
                        dropdown.classList.remove("show");
                        if (notiDropdown.classList.contains("show")) {
                            loadNotifications(user.id);
                        }
                    };
                }

                async function loadNotifications(userId) {
                    try {
                        console.log(`🔔 Fetching notifications for User: ${userId}`);
                        const response = await fetch(`/api/notifications/${userId}`);
                        const notifications = await response.json();
                        console.log(`📥 Received ${notifications.length} notifications`, notifications);
                        renderNotifications(notifications);
                    } catch (err) { console.error("Lỗi tải thông báo:", err); }
                }

                function renderNotifications(notis) {
                    const container = document.getElementById('noti-list-container');
                    const countBadge = document.getElementById('noti-count');

                    if (!container) return;

                    const unreadCount = notis.filter(n => !n.is_read).length;
                    console.log(`📊 Unread count: ${unreadCount}`);
                    if (unreadCount > 0) {
                        countBadge.innerText = unreadCount > 99 ? '99+' : unreadCount;
                        countBadge.style.display = 'flex';
                    } else {
                        countBadge.style.display = 'none';
                    }

                    if (notis.length === 0) {
                        container.innerHTML = `<div style="padding: 30px; text-align: center; color: #a0aec0;">Không có thông báo nào</div>`;
                        return;
                    }

                    container.innerHTML = notis.map(n => {
                        let iconClass = 'default';
                        let iconItem = 'fa-bell';
                        if (n.type === 'membership') { iconClass = 'membership'; iconItem = 'fa-user-check'; }
                        else if (n.type === 'post') { iconClass = 'post'; iconItem = 'fa-file-alt'; }
                        else if (n.type === 'event') { iconClass = 'event'; iconItem = 'fa-calendar-alt'; }

                        return `
                        <a href="${n.link || '#'}" class="noti-item ${n.is_read ? '' : 'unread'}" onclick="handleNotiClick(event, ${n.id}, '${n.link}')">
                            <div class="noti-icon ${iconClass}">
                                <i class="fas ${iconItem}"></i>
                            </div>
                            <div class="noti-content">
                                <div class="noti-title">
                                    ${n.title}
                                    <span class="noti-indicator"></span>
                                </div>
                                <span class="noti-msg">${n.message}</span>
                                <span class="noti-time">${new Date(n.created_at).toLocaleString('vi-VN')}</span>
                            </div>
                        </a>
                        `;
                    }).join('');
                }

                window.handleNotiClick = async function (e, id, link) {
                    if (link === '#' || !link) e.preventDefault();
                    try {
                        await fetch(`/api/notifications/read/${id}`, { method: 'PUT' });
                    } catch (err) { console.error(err); }
                };

                window.markAllAsRead = async function () {
                    try {
                        await fetch(`/api/notifications/read-all/${user.id}`, { method: 'PUT' });
                        loadNotifications(user.id);
                    } catch (err) { console.error(err); }
                };

                // --- Real-time Socket.io ---
                const socket = io();

                socket.on('connect', () => {
                    console.log("📡 Socket connected:", socket.id);
                    socket.emit("register", user.id);
                });

                socket.on("new_notification", (data) => {
                    console.log("⚡ Real-time notification received:", data);
                    showToast(data.title, data.message, data.type);
                    loadNotifications(user.id);
                });

                socket.on('disconnect', () => {
                    console.log("🔌 Socket disconnected");
                });

                function showToast(title, message, type = 'info') {
                    const toastContainer = document.getElementById('thong-bao-toast');
                    if (!toastContainer) return;

                    const toast = document.createElement('div');
                    toast.className = `toast-item ${type}`;

                    let icon = 'fa-bell';
                    if (type === 'membership') icon = 'fa-user-check';
                    else if (type === 'success') icon = 'fa-check-circle';

                    toast.innerHTML = `
                        <div class="toast-icon">
                            <i class="fas ${icon}"></i>
                        </div>
                        <div class="toast-content">
                            <div class="toast-title">${title}</div>
                            <div class="toast-msg">${message}</div>
                        </div>
                    `;

                    toastContainer.appendChild(toast);
                    setTimeout(() => toast.classList.add('active'), 100);

                    setTimeout(() => {
                        toast.classList.remove('active');
                        setTimeout(() => toast.remove(), 500);
                    }, 5000);
                }

                // Initial load
                loadNotifications(user.id);

                // Đóng menu nếu click ra ngoài vùng user-info hoặc noti-btn
                window.onclick = function (event) {
                    if (!profileBtn.contains(event.target)) {
                        dropdown.classList.remove("show");
                    }
                    if (notiBtn && !notiBtn.contains(event.target)) {
                        notiDropdown.classList.remove("show");
                    }
                };
                return;
            }
        }

        // Trạng thái Khách
        const notiBtnGuest = document.getElementById('noti-btn');
        if (notiBtnGuest) notiBtnGuest.style.display = 'none';

        usernameEl.textContent = "Khách";
        avatarEl.textContent = "?";
        avatarEl.style.background = "#718096";

        profileBtn.onclick = function () {
            window.location.href = "/dangnhap";
        };
    });
</script>