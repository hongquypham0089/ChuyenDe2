<%- include('partials/Header') %>

    <!-- Main Content -->
    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <h1 class="page-title">Sự kiện sinh viên</h1>
            <div style="display: flex; gap: 16px;">
                <div class="view-toggle">
                    <button class="view-btn active" onclick="toggleView('grid')"><i class="fas fa-th-large"></i> Grid</button>
                    <button class="view-btn" onclick="toggleView('calendar')"><i class="fas fa-calendar"></i> Lịch</button>
                </div>
                <button class="btn-create" onclick="openCreateEventModal()">
                    <i class="fas fa-plus-circle"></i> Tạo sự kiện
                </button>
            </div>
        </div>

        <!-- My Events Section -->
        <div class="my-events">
            <h3><i class="fas fa-star"></i> Sự kiện của tôi</h3>
            <div id="myEventsList">
                <div class="my-event-item" data-event="workshop-react">
                    <div class="my-event-date">
                        <span class="day">15</span>
                        <span class="month">TH4</span>
                    </div>
                    <div class="my-event-info">
                        <h4>Workshop: Lập trình Web với React</h4>
                        <p><i class="fas fa-clock"></i> 18:00 - 21:00 · CLB Tin học</p>
                    </div>
                    <button class="btn-cancel-event" onclick="cancelMyEvent(this)">Hủy tham gia</button>
                </div>
                <div class="my-event-item" data-event="music-night">
                    <div class="my-event-date">
                        <span class="day">20</span>
                        <span class="month">TH4</span>
                    </div>
                    <div class="my-event-info">
                        <h4>Đêm nhạc GACOUSTIC - Giai điệu mùa hè</h4>
                        <p><i class="fas fa-clock"></i> 19:00 - 22:00 · CLB Âm nhạc</p>
                    </div>
                    <button class="btn-cancel-event" onclick="cancelMyEvent(this)">Hủy tham gia</button>
                </div>
            </div>
        </div>

        <!-- Filter Section -->
        <div class="filter-section">
            <div class="filter-tabs">
                <span class="filter-tab active" onclick="filterEvents('all')">Tất cả sự kiện</span>
                <span class="filter-tab" onclick="filterEvents('upcoming')">Sắp diễn ra</span>
                <span class="filter-tab" onclick="filterEvents('ongoing')">Đang diễn ra</span>
                <span class="filter-tab" onclick="filterEvents('ended')">Đã kết thúc</span>
                <span class="filter-tab" onclick="filterEvents('my-clubs')">Từ CLB của tôi</span>
            </div>
            
            <div class="date-filter">
                <div class="date-input">
                    <i class="fas fa-calendar-alt"></i>
                    <input type="date" id="startDate" onchange="filterByDate()">
                </div>
                <span>→</span>
                <div class="date-input">
                    <i class="fas fa-calendar-alt"></i>
                    <input type="date" id="endDate" onchange="filterByDate()">
                </div>
                <button class="filter-tab" style="background: #c53030; color: white;" onclick="clearDateFilter()">Xóa lọc</button>
            </div>
        </div>

        <!-- Events Grid View -->
        <div id="gridView" class="event-grid">
            <!-- Event 1 - Workshop React -->
            <div class="event-card" data-status="upcoming" data-club="it" data-date="2026-04-15" onclick="showEventDetail('react-workshop')">
                <div class="event-image">
                    <img src="https://images.unsplash.com/photo-1505373877841-8d25f7d46678?w=600" alt="Workshop React">
                    <span class="event-badge badge-upcoming">Sắp diễn ra</span>
                    <span class="event-club">CLB Tin học</span>
                </div>
                <div class="event-content">
                    <h3 class="event-title">Workshop: Lập trình Web với React - Từ A đến Z</h3>
                    <p class="event-desc">Workshop thực hành thiết kế giao diện web với React. Giảng viên: Kỹ sư từ FPT Software với 5 năm kinh nghiệm.</p>
                    <div class="event-details">
                        <div class="event-detail-item">
                            <i class="fas fa-calendar"></i>
                            <span>15/04/2026</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-clock"></i>
                            <span>18:00 - 21:00</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <span>Phòng A101 - ĐH Bách Khoa</span>
                        </div>
                    </div>
                    <div class="event-stats">
                        <div class="registered-count">
                            <i class="fas fa-users"></i>
                            <span>72/100 đã đăng ký</span>
                        </div>
                        <div class="capacity-bar">
                            <div class="capacity-fill" style="width: 72%"></div>
                        </div>
                    </div>
                    <div class="event-footer">
                        <button class="btn-detail" onclick="event.stopPropagation(); showEventDetail('react-workshop')">Xem chi tiết</button>
                        <button class="btn-register registered" onclick="event.stopPropagation(); toggleRegister(this)"><i class="fas fa-check"></i> Đã tham gia</button>
                    </div>
                </div>
            </div>

            <!-- Event 2 - Đêm nhạc -->
            <div class="event-card" data-status="upcoming" data-club="music" data-date="2026-04-20" onclick="showEventDetail('music-night')">
                <div class="event-image">
                    <img src="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?w=600" alt="Đêm nhạc">
                    <span class="event-badge badge-upcoming">Sắp diễn ra</span>
                    <span class="event-club">CLB Âm nhạc</span>
                </div>
                <div class="event-content">
                    <h3 class="event-title">Đêm nhạc GACOUSTIC - Giai điệu mùa hè</h3>
                    <p class="event-desc">Đêm nhạc acoustic với sự tham gia của các ca sĩ khách mời và các tài năng âm nhạc từ CLB. Gây quỹ ủng hộ trẻ em vùng cao.</p>
                    <div class="event-details">
                        <div class="event-detail-item">
                            <i class="fas fa-calendar"></i>
                            <span>20/04/2026</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-clock"></i>
                            <span>19:00 - 22:00</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <span>Hội trường lớn - ĐH Xây dựng</span>
                        </div>
                    </div>
                    <div class="event-stats">
                        <div class="registered-count">
                            <i class="fas fa-users"></i>
                            <span>156/200 đã đăng ký</span>
                        </div>
                        <div class="capacity-bar">
                            <div class="capacity-fill" style="width: 78%"></div>
                        </div>
                    </div>
                    <div class="event-footer">
                        <button class="btn-detail" onclick="event.stopPropagation(); showEventDetail('music-night')">Xem chi tiết</button>
                        <button class="btn-register registered" onclick="event.stopPropagation(); toggleRegister(this)"><i class="fas fa-check"></i> Đã tham gia</button>
                    </div>
                </div>
            </div>

            <!-- Event 3 - Mùa hè xanh -->
            <div class="event-card" data-status="upcoming" data-club="volunteer" data-date="2026-04-25" onclick="showEventDetail('summer-campaign')">
                <div class="event-image">
                    <img src="https://images.unsplash.com/photo-1469571486292-0ba58a3f068b?w=600" alt="Mùa hè xanh">
                    <span class="event-badge badge-upcoming">Sắp diễn ra</span>
                    <span class="event-club">CLB Tình nguyện</span>
                </div>
                <div class="event-content">
                    <h3 class="event-title">Chiến dịch "Mùa hè xanh" 2026 - Vì biển đảo</h3>
                    <p class="event-desc">Hành trình tình nguyện 7 ngày tại huyện đảo. Tham gia dạy học, tặng quà và bảo vệ môi trường biển.</p>
                    <div class="event-details">
                        <div class="event-detail-item">
                            <i class="fas fa-calendar"></i>
                            <span>25-30/04/2026</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-clock"></i>
                            <span>07:00 - 17:00</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <span>Huyện đảo Cô Tô</span>
                        </div>
                    </div>
                    <div class="event-stats">
                        <div class="registered-count">
                            <i class="fas fa-users"></i>
                            <span>89/100 đã đăng ký</span>
                        </div>
                        <div class="capacity-bar">
                            <div class="capacity-fill" style="width: 89%"></div>
                        </div>
                    </div>
                    <div class="event-footer">
                        <button class="btn-detail" onclick="event.stopPropagation(); showEventDetail('summer-campaign')">Xem chi tiết</button>
                        <button class="btn-register" onclick="event.stopPropagation(); toggleRegister(this)">Tham gia</button>
                    </div>
                </div>
            </div>

            <!-- Event 4 - AI Conference -->
            <div class="event-card" data-status="upcoming" data-club="it" data-date="2026-05-10" onclick="showEventDetail('ai-conference')">
                <div class="event-image">
                    <img src="https://images.unsplash.com/photo-1485827404703-89b55fcc595e?w=600" alt="AI Conference">
                    <span class="event-badge badge-upcoming">Sắp diễn ra</span>
                    <span class="event-club">CLB Tin học</span>
                </div>
                <div class="event-content">
                    <h3 class="event-title">Hội thảo AI & Machine Learning 2026</h3>
                    <p class="event-desc">Hội thảo với sự tham gia của các chuyên gia AI hàng đầu từ Google, FPT. Cơ hội học hỏi và networking.</p>
                    <div class="event-details">
                        <div class="event-detail-item">
                            <i class="fas fa-calendar"></i>
                            <span>10/05/2026</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-clock"></i>
                            <span>08:00 - 17:00</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <span>Trung tâm Hội nghị Quốc gia</span>
                        </div>
                    </div>
                    <div class="event-stats">
                        <div class="registered-count">
                            <i class="fas fa-users"></i>
                            <span>45/150 đã đăng ký</span>
                        </div>
                        <div class="capacity-bar">
                            <div class="capacity-fill" style="width: 30%"></div>
                        </div>
                    </div>
                    <div class="event-footer">
                        <button class="btn-detail" onclick="event.stopPropagation(); showEventDetail('ai-conference')">Xem chi tiết</button>
                        <button class="btn-register" onclick="event.stopPropagation(); toggleRegister(this)">Tham gia</button>
                    </div>
                </div>
            </div>

            <!-- Event 5 - Giải bóng đá -->
            <div class="event-card" data-status="ongoing" data-club="sports" data-date="2026-03-01" onclick="showEventDetail('football-tournament')">
                <div class="event-image">
                    <img src="https://images.unsplash.com/photo-1579952363873-27f3bade9f55?w=600" alt="Giải bóng đá">
                    <span class="event-badge badge-ongoing">Đang diễn ra</span>
                    <span class="event-club">CLB Thể thao</span>
                </div>
                <div class="event-content">
                    <h3 class="event-title">Giải bóng đá sinh viên mở rộng 2026</h3>
                    <p class="event-desc">Giải đấu quy tụ 16 đội bóng đến từ các trường đại học trên địa bàn Hà Nội.</p>
                    <div class="event-details">
                        <div class="event-detail-item">
                            <i class="fas fa-calendar"></i>
                            <span>01-30/03/2026</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-clock"></i>
                            <span>08:00 - 17:00</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <span>Sân vận động Mỹ Đình</span>
                        </div>
                    </div>
                    <div class="event-stats">
                        <div class="registered-count">
                            <i class="fas fa-users"></i>
                            <span>16/16 đội</span>
                        </div>
                        <div class="capacity-bar">
                            <div class="capacity-fill" style="width: 100%"></div>
                        </div>
                    </div>
                    <div class="event-footer">
                        <button class="btn-detail" onclick="event.stopPropagation(); showEventDetail('football-tournament')">Xem chi tiết</button>
                        <button class="btn-register" disabled style="background: #94a3b8;">Đã đủ đội</button>
                    </div>
                </div>
            </div>

            <!-- Event 6 - English Speaking -->
            <div class="event-card" data-status="ended" data-club="english" data-date="2026-02-28" onclick="showEventDetail('english-club')">
                <div class="event-image">
                    <img src="https://images.unsplash.com/photo-1546410531-bb4caa6b424d?w=600" alt="English Club">
                    <span class="event-badge badge-ended">Đã kết thúc</span>
                    <span class="event-club">CLB Tiếng Anh</span>
                </div>
                <div class="event-content">
                    <h3 class="event-title">English Speaking Contest 2026</h3>
                    <p class="event-desc">Cuộc thi hùng biện tiếng Anh với chủ đề "Công nghệ và Tương lai".</p>
                    <div class="event-details">
                        <div class="event-detail-item">
                            <i class="fas fa-calendar"></i>
                            <span>28/02/2026</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-clock"></i>
                            <span>14:00 - 17:00</span>
                        </div>
                        <div class="event-detail-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <span>Hội trường C2</span>
                        </div>
                    </div>
                    <div class="event-stats">
                        <div class="registered-count">
                            <i class="fas fa-users"></i>
                            <span>120 người tham dự</span>
                        </div>
                    </div>
                    <div class="event-footer">
                        <button class="btn-detail" onclick="event.stopPropagation(); showEventDetail('english-club')">Xem chi tiết</button>
                        <button class="btn-register" disabled style="background: #94a3b8;">Đã kết thúc</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Calendar View -->
        <div id="calendarView" class="calendar-view">
            <div id="calendar"></div>
        </div>
    </div>

    <!-- Event Detail Modal -->
    <div class="modal" id="eventDetailModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="detailEventTitle">Workshop: Lập trình Web với React</h3>
                <button class="close-btn" onclick="closeModal('eventDetailModal')"><i class="fas fa-times"></i></button>
            </div>
            
            <div class="event-detail-header">
                <div class="detail-image">
                    <img id="detailEventImage" src="https://images.unsplash.com/photo-1505373877841-8d25f7d46678?w=600" alt="Event">
                </div>
                <div class="detail-info">
                    <span class="detail-club" id="detailEventClub">CLB Tin học</span>
                    <h2 id="detailEventName">Workshop: Lập trình Web với React - Từ A đến Z</h2>
                    <div class="detail-meta">
                        <span><i class="fas fa-users"></i> <span id="detailRegistered">72</span>/<span id="detailCapacity">100</span> đã đăng ký</span>
                    </div>
                    <span class="detail-status badge-upcoming" id="detailEventStatus">Sắp diễn ra</span>
                </div>
            </div>

            <div class="detail-section">
                <h4><i class="fas fa-info-circle"></i> Thông tin chi tiết</h4>
                <div class="detail-info-grid" id="detailInfoGrid">
                    <div class="info-item">
                        <i class="fas fa-calendar-alt"></i>
                        <div>
                            <div style="font-weight: 600;">Thời gian</div>
                            <div id="detailDateTime">18:00 - 21:00, 15/04/2026</div>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <div>
                            <div style="font-weight: 600;">Địa điểm</div>
                            <div id="detailLocation">Phòng A101 - ĐH Bách Khoa</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="detail-section">
                <h4><i class="fas fa-align-left"></i> Mô tả sự kiện</h4>
                <p id="detailDescription">Workshop thực hành thiết kế giao diện web với React. Giảng viên: Kỹ sư từ FPT Software với 5 năm kinh nghiệm. Nội dung bao gồm: React Hooks, State Management, Routing, và thực hành dự án mini.</p>
            </div>

            <div class="detail-section">
                <h4><i class="fas fa-chalkboard-teacher"></i> Diễn giả</h4>
                <div class="speaker-list" id="detailSpeakers">
                    <div class="speaker-item">
                        <div class="speaker-avatar">NA</div>
                        <div>
                            <div style="font-weight: 600;">Nguyễn Văn A</div>
                            <div style="font-size: 12px; color: #64748b;">Senior Developer, FPT Software</div>
                        </div>
                    </div>
                    <div class="speaker-item">
                        <div class="speaker-avatar">TB</div>
                        <div>
                            <div style="font-weight: 600;">Trần Thị B</div>
                            <div style="font-size: 12px; color: #64748b;">Technical Lead, VNG</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="detail-section">
                <h4><i class="fas fa-clock"></i> Lịch trình</h4>
                <ul style="list-style: none;" id="detailSchedule">
                    <li style="margin-bottom: 10px;">• 18:00 - 18:30: Check-in</li>
                    <li style="margin-bottom: 10px;">• 18:30 - 19:30: Giới thiệu React Hooks</li>
                    <li style="margin-bottom: 10px;">• 19:30 - 19:45: Nghỉ giải lao</li>
                    <li style="margin-bottom: 10px;">• 19:45 - 20:45: Thực hành dự án</li>
                    <li style="margin-bottom: 10px;">• 20:45 - 21:00: Hỏi đáp và networking</li>
                </ul>
            </div>

            <div class="modal-actions">
                <button class="btn-primary" id="detailRegisterBtn" onclick="toggleRegisterFromDetail()">
                    <i class="fas fa-user-plus"></i> Tham gia sự kiện
                </button>
                <button class="btn-secondary" onclick="closeModal('eventDetailModal')">
                    Đóng
                </button>
            </div>
        </div>
    </div>

    <!-- Create Event Modal -->
    <div class="modal" id="createEventModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-plus-circle" style="color: #c53030;"></i> Tạo sự kiện mới</h3>
                <button class="close-btn" onclick="closeModal('createEventModal')"><i class="fas fa-times"></i></button>
            </div>

            <form id="createEventForm" onsubmit="event.preventDefault(); createEvent();">
                <div class="form-group">
                    <label>Tên sự kiện</label>
                    <input type="text" id="eventName" placeholder="VD: Workshop React" required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>CLB tổ chức</label>
                        <select id="eventClub" required>
                            <option value="">Chọn CLB</option>
                            <option value="it">CLB Tin học</option>
                            <option value="music">CLB Âm nhạc</option>
                            <option value="volunteer">CLB Tình nguyện</option>
                            <option value="sports">CLB Thể thao</option>
                            <option value="english">CLB Tiếng Anh</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Loại sự kiện</label>
                        <select id="eventType">
                            <option value="workshop">Workshop</option>
                            <option value="seminar">Hội thảo</option>
                            <option value="competition">Cuộc thi</option>
                            <option value="volunteer">Tình nguyện</option>
                            <option value="cultural">Văn hóa - Văn nghệ</option>
                            <option value="sports">Thể thao</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Ngày bắt đầu</label>
                        <input type="date" id="eventStartDate" required>
                    </div>
                    <div class="form-group">
                        <label>Ngày kết thúc</label>
                        <input type="date" id="eventEndDate" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Giờ bắt đầu</label>
                        <input type="time" id="eventStartTime" required>
                    </div>
                    <div class="form-group">
                        <label>Giờ kết thúc</label>
                        <input type="time" id="eventEndTime" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Địa điểm</label>
                    <input type="text" id="eventLocation" placeholder="Phòng A101 - ĐH Bách Khoa" required>
                </div>

                <div class="form-group">
                    <label>Mô tả sự kiện</label>
                    <textarea id="eventDescription" placeholder="Mô tả chi tiết về sự kiện..." rows="4" required></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Số lượng tối đa</label>
                        <input type="number" id="eventCapacity" placeholder="100" min="1">
                    </div>
                    <div class="form-group">
                        <label>Hạn đăng ký</label>
                        <input type="date" id="eventDeadline">
                    </div>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-image"></i> Ảnh sự kiện</label>
                    <div class="image-upload" onclick="document.getElementById('eventImage').click()">
                        <i class="fas fa-cloud-upload-alt"></i>
                        <p>Click để tải ảnh lên</p>
                    </div>
                    <input type="file" id="eventImage" accept="image/*" style="display: none;">
                </div>

                <div class="modal-actions">
                    <button type="submit" class="btn-submit">
                        <i class="fas fa-check-circle"></i> Tạo sự kiện
                    </button>
                    <button type="button" class="btn-cancel" onclick="closeModal('createEventModal')">
                        Hủy
                    </button>
                </div>
            </form>
        </div>
    </div>

    <link rel="stylesheet" href="CSS/SuKien.css">
    <link rel="stylesheet" href="JS/SuKien.js">
<%- include('partials/Footer') %>
